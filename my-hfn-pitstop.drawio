        <mxCell id="j5B9NYO59L7RkcTgPj0m-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;dashPattern=8 8;align=left;spacing=12;" value="Props&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;quote: Quote&lt;br&gt;isDialogOpen: boolean&lt;br&gt;onCancel: () =&amp;gt; void&lt;/div&gt;&lt;div&gt;addOBTBookmark: (bookmark: IOBTBookmark) =&amp;gt; Promise&amp;lt;void&amp;gt;&lt;/div&gt;&lt;br&gt;addNewOBTLabel: (label: string) =&amp;gt; Promise&amp;lt;void&amp;gt;&lt;br&gt;fetchOBTLabels: () =&amp;gt; Promise&amp;lt;string[]&amp;gt;" vertex="1">
