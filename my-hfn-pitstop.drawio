        <mxCell id="z6bcM04By5YTDC8IDdeT-42" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Language:&lt;/b&gt; English" vertex="1">
